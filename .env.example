# ══════════════════════════════════════════════════════════════════
#  Aurx AI — Variables de entorno
#  Copia este archivo como .env y rellena tus valores reales.
#  En Render: ve a Environment → Add Environment Variable
# ══════════════════════════════════════════════════════════════════

# ── Servidor ────────────────────────────────────────────────────
PORT=3000

# ── Firebase ─────────────────────────────────────────────────────
# FIREBASE_SERVICE_ACCOUNT: pega el JSON completo de la cuenta de servicio
#   (Firebase Console → Project Settings → Service accounts → Generate new private key)
#   En Render pégalo como una sola línea sin saltos de línea.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# URL de tu Realtime Database (se encuentra en Firebase Console → Realtime Database)
FIREBASE_DB_URL=https://tu-proyecto-default-rtdb.firebaseio.com

# Web API Key (Firebase Console → Project Settings → General → Web API Key)
FIREBASE_API_KEY=AIza...

# ── Proveedores de IA ────────────────────────────────────────────
# OpenAI  → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (Claude)  → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)  → https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...

# xAI (Grok)  → https://console.x.ai/
GROK_API_KEY=xai-...
